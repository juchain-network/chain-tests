# Runtime backend selector for chain-tests
runtime:
  # Options: docker | native
  backend: native
  # Runtime implementation mode:
  # - single: all nodes use runtime.impl
  # - mixed:  per-node implementation from runtime_nodes.nodeX
  impl_mode: single
  # Default implementation when impl_mode=single (or runtime_nodes fallback):
  # geth | reth
  impl: geth

paths:
  # Supports relative paths, resolved from chain-tests repo root.
  chain_root: "../chain-1.16/chain-1.16"
  reth_root: "../rchain"
  chain_contract_root: "../chain-contract"
  reth_bytecode_file: "../rchain/crates/congress-core/src/bytecode.rs"
  # Other paths are derived by default:
  # - geth binary: <chain_root>/build/bin/geth
  # - reth binary: <reth_root>/target/release/congress-node
  # - contracts out: <chain_contract_root>/out

binaries:
  # Optional explicit binary overrides. Empty means auto-detect from paths.* roots.
  geth_native: ""
  reth_native: ""
  geth_docker: ""
  reth_docker: ""

# Optional per-node implementation mapping for runtime.impl_mode=mixed.
runtime_nodes:
  node0: geth
  node1: geth
  node2: geth
  node3: reth

# Validator credential policy used by reth nodes.
validator_auth:
  # auto: keystore first, fallback to private key
  # private_key: force --validator-private-key
  # keystore: force --keystore-* args
  mode: auto
  keystore:
    # If empty, default: data/nodeX/password.txt
    password_file: ""
    # Optional fallback env var name for keystore pass when password_file not set.
    password_env: ""

# Blacklist test/runtime toggles.
# mode:
# - mock: predeploy chain-tests managed mock contract and run deterministic regression
# - real: use existing on-chain contract address without mock injection
blacklist:
  enabled: true
  mode: "mock"
  contract_address: "0x1db0EDE439708A923431DC68fd3F646c0A4D4e6E"
  # If true, blacklist init failures are treated as fail-open and must emit alert logs.
  alert_fail_open: true
  mock:
    predeploy: true
    code_file: "./templates/blacklist/mock_runtime_hex.txt"
    abi_file: "./templates/blacklist/mock_abi.json"

# Shared settings for both backends
network:
  node_count: 4
  validator_count: 3
  # Genesis mode for chain startup:
  # - poa: start from PoA system contracts
  # - upgrade: start from PoA and schedule one fork-time transition
  # - posa: direct PoSA startup
  genesis_mode: "posa"
  # Used only when genesis_mode=upgrade.
  # Valid values:
  # - shanghaiTime | cancunTime | posaTime | fixHeaderTime
  # - allStaggered  -> shanghai/cancun/fixHeader/posa all non-zero and +60s increment
  # - allSame       -> shanghai/cancun/fixHeader/posa all equal and non-zero
  fork_target: ""
  # Fork activation delay from init time (seconds), upgrade mode only.
  fork_delay_seconds: 120
  # Prefund Staking (0x...f013) with min stake * validator_count before block #1.
  # Required for newer contract/binary combinations where initializeWithValidators
  # validates staking contract balance during init.
  prefund_staking_initial_stake: true
  # Unit: wei per validator (default 1 ETH).
  min_validator_stake_wei: "1000000000000000000"
  # Epoch length in blocks (smaller value speeds up epoch-bound tests).
  # Can be overridden at runtime by: make init EPOCH=60
  # (internally sets TEST_NETWORK_EPOCH).
  epoch: 30
  external_rpc: "http://localhost:18545"
  chain_id: 666666
  data_dir: "./data"
  reports_dir: "./reports"

# Docker backend settings
docker:
  compose_file: "./docker/docker-compose.yml"
  runtime_compose_file: "./data/docker-compose.runtime.yml"
  project_name: "juchain-it"
  external_rpc: "http://localhost:18545"

# Native backend settings (recommended for local dev speed)
native:
  manager: pm2
  init_script: "./scripts/native/pm2_init.sh"
  ecosystem_file: "./native/ecosystem.config.js"
  env_file: "./data/native/.env"
  # For geth >= 1.16, hash scheme avoids known path-scheme state freezer lock issues.
  state_scheme: "hash"
  # Optional: keep empty to use geth default (90000). Set "0" for full history if needed.
  history_state: ""
  network_id: 666666
  external_rpc: "http://localhost:18545"
  pm2_namespace: "ju-chain"
  log_dir: "./data/native-logs"
  ports:
    validator1_http: 18545
    validator1_ws: 18546
    validator1_engine: 18550
    validator1_p2p: 30301
    validator2_http: 18547
    validator2_ws: 18548
    validator2_engine: 18552
    validator2_p2p: 30303
    validator3_http: 18549
    validator3_ws: 18553
    validator3_engine: 18554
    validator3_p2p: 30305
    sync_http: 18551
    sync_ws: 18555
    sync_engine: 18556
    sync_p2p: 30307

# Test runner settings
tests:
  # Profile selector: fast | default | edge
  # Can be overridden per run via env TEST_PROFILE.
  profile: fast
  timeout: "30m"
  smoke:
    # Smoke liveness observe window (seconds). Default is 5 minutes.
    observe_seconds: 300
  reset_before_each_case: true
  # Optional epoch overrides for faster/stabler grouped execution.
  # Resolution order:
  # 1) env EPOCH
  # 2) tests.epoch_overrides.<scope>.<name>
  # 3) tests.epoch_overrides.groups.default (group scope only)
  # 4) tests.profiles.<profile>.epoch
  # 5) network.epoch
  epoch_overrides:
    groups:
      # Applied to make test-<group> unless group-specific key exists.
      default: 30
      # Example: lower epoch only for groups that benefit in runtime.
      staking: 15
      punish: 18
      epoch: 20
    specials:
      # Used by make test-punish second phase (TestG_DoubleSign).
      punish_double_sign: 18
  # Parameter presets for different test speed/stability trade-offs.
  profiles:
    fast:
      epoch: 30
      proposal_cooldown: 1
      unbonding_period: 3
      validator_unjail_period: 3
      withdraw_profit_period: 2
      commission_update_cooldown: 1
      proposal_lasting_period: 30
    default:
      epoch: 60
      proposal_cooldown: 1
      unbonding_period: 10
      validator_unjail_period: 10
      withdraw_profit_period: 5
      commission_update_cooldown: 5
      proposal_lasting_period: 100
    edge:
      epoch: 60
      proposal_cooldown: 60
      unbonding_period: 60
      validator_unjail_period: 60
      withdraw_profit_period: 30
      commission_update_cooldown: 30
      proposal_lasting_period: 300

# Performance/soak defaults (used by make test-perf-* and scripts/perf/*).
perf:
  # Transactions per second tiers for quick perf profile.
  tps_tiers: [10, 30, 60]
  sample_interval_seconds: 2
  soak:
    duration: "24h"
    tps: 10
    restart_interval: "1h"
  thresholds:
    success_rate_min: 0.99
    stall_window_seconds_max: 15
    max_height_lag: 8
    rpc_latency_p95_ms_max: 500

# CI defaults (consumed by make ci-pr-gate / ci-nightly-full / ci-weekly-soak).
ci:
  pr_gate:
    groups: "config,governance,staking,punish,epoch"
    run_smoke: true
  nightly:
    groups: "config,governance,staking,delegation,punish,rewards,epoch"
    run_smoke: true
    run_fork_all: true
    run_posa: true
    # Required compatibility path: reth + keystore mode.
    run_reth_keystore_smoke: true
  release_gate:
    run_smoke: true
    run_fork_all: true
    run_posa: true
  weekly_soak:
    enabled: true
